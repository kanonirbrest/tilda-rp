# Скопируйте в .env.production и заполните. Для compose: см. docker-compose.prod.yml

# Пароль пользователя PostgreSQL (тот же пароль подставляется в DATABASE_URL для сервиса app)
POSTGRES_PASSWORD="смените_на_сильный_пароль"

# При docker compose -f docker-compose.prod.yml переменная DATABASE_URL для контейнера app
# задаётся в compose (хост postgres). Вне compose укажите полный URL на вашу БД.
# DATABASE_URL="postgresql://user:pass@host:5432/dei_tickets"

# Публичный URL сайта (HTTPS в продакшене) — ссылки в QR, редиректы bePaid, письма
APP_BASE_URL="https://tickets.example.com"

SESSION_SECRET="случайная_строка_32plus_символов"

DEV_SKIP_PAYMENT="false"

BEPAID_SHOP_ID=""
BEPAID_SECRET_KEY=""
# Не задавайте старый gateway …/beyag/payments (404). По умолчанию — checkout.bepaid.by
# BEPAID_API_URL="https://checkout.bepaid.by/ctp/api/checkouts"
# На проде обычно false. true — тестовый режим bePaid (без реального списания).
BEPAID_TEST="false"

SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="tickets@example.com"

TILDA_CRM_WEBHOOK_URL=""
TILDA_CRM_WEBHOOK_SECRET=""

# Origin(ы) Тильды/лендинга для fetch → POST /api/orders (через запятую, без слэша в конце)
# PUBLIC_ORDERS_CORS_ORIGIN="https://project12345.tilda.ws"

SUPPORT_EMAIL="support@example.com"

# Встроенная админка /admin (тот же секрет для входа и для Bearer к API при необходимости)
# ADMIN_API_SECRET=""
# ADMIN_CORS_ORIGIN=""  # только для внешних origin к /api/admin/*

# Опционально: не запускать миграции при старте контейнера (1 = пропустить)
# SKIP_DB_MIGRATE=0
