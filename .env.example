# База (локально: поднимите docker compose, затем этот URL)
DATABASE_URL="postgresql://dei:dei@localhost:5433/dei_tickets"

# Публичный URL приложения (для ссылок в QR и письмах)
# С телефона по Wi‑Fi: http://192.168.x.x:ПОРТ — тот же хост подставится в allowedDevOrigins (HMR/WebSocket).
# На Render можно не задавать: используется RENDER_EXTERNAL_URL (https://…onrender.com).
APP_BASE_URL="http://localhost:3000"
# Часовой пояс для сопоставления даты/времени из Тильды со слотами в БД (date + time в query)
# EXHIBITION_TIMEZONE="Europe/Minsk"
# Опционально: явный список хостов для dev HMR, через запятую (если не хотите парсить APP_BASE_URL)
# ALLOWED_DEV_ORIGINS=192.168.1.7

# Секрет для JWT сессии персонала (случайная строка 32+ символов)
SESSION_SECRET="замените_на_случайную_длинную_строку"

# Режим разработки: пропустить bePaid и сразу «оплатить» заказ
DEV_SKIP_PAYMENT="true"

# bePaid (когда подключите реальный магазин)
BEPAID_SHOP_ID=""
BEPAID_SECRET_KEY=""
# true = тестовая транзакция bePaid (test: true), см. https://docs.bepaid.by/ru/using_api/testing/
BEPAID_TEST="false"
# URL API bePaid — уточните в личном кабинете / документации для вашего продукта
BEPAID_API_URL="https://gateway.bepaid.by/beyag/payments"

# Почта (после оплаты — билет на email). Без SMTP письма только логируются в консоль.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="tickets@dei.by"

# CORS для POST /api/orders со страниц Тильды (origin через запятую). В dev не обязателен.
# Пример: PUBLIC_ORDERS_CORS_ORIGIN="https://project12345.tilda.ws,https://www.dei.by"
# PUBLIC_ORDERS_CORS_ORIGIN=""

# Вебхук в Tilda CRM / Make / свой приёмник (POST JSON). Пусто = не отправлять.
TILDA_CRM_WEBHOOK_URL=""
TILDA_CRM_WEBHOOK_SECRET=""

# Поддержка (текст на странице успеха)
SUPPORT_EMAIL="support@dei.by"

# Админка /admin и API /api/admin/*: случайная длинная строка (вводится на странице входа)
# ADMIN_API_SECRET=""
# Только если дергаете /api/admin/* с другого сайта — origin через запятую
# ADMIN_CORS_ORIGIN="https://другой-домен"
