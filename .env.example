# База (локально: поднимите docker compose, затем этот URL)
DATABASE_URL="postgresql://dei:dei@localhost:5433/dei_tickets"

# Публичный URL приложения (для ссылок в QR и письмах)
# С телефона по Wi‑Fi: http://192.168.x.x:ПОРТ — тот же хост подставится в allowedDevOrigins (HMR/WebSocket).
# На Render можно не задавать: используется RENDER_EXTERNAL_URL (https://…onrender.com).
APP_BASE_URL="http://localhost:3000"
# PDF билета: один HTML → PDF.
# Движок: playwright (по умолчанию, Chromium) или prince (Prince XML — установите https://www.princexml.com/)
# TICKET_PDF_RENDERER="playwright"
# PRINCE_BIN="/usr/local/bin/prince"
# Перед первым запуском Playwright: npx playwright install chromium
# В Docker (образ из Dockerfile): Chromium кладётся в /opt/ms-playwright, переменная задаётся в Dockerfile.
# Если HOME у процесса «фиктивный» (/nonexistent), без PLAYWRIGHT_BROWSERS_PATH PDF не соберётся.
# PLAYWRIGHT_BROWSERS_PATH="/opt/ms-playwright"
# Фон билета: по умолчанию assets/tickets/ticket-background.png (градиент без текста).
# Дальше по очереди: ticket-background.jpg, assets/tickets/7777.jpg (JPEG из Figma).
# Свой файл (PNG/JPEG/WebP): TICKET_PDF_ARTWORK="/abs/path/to.jpg"
# Многострочный юридический текст билета (переносы строк сохраняются):
# TICKET_LEGAL_BLOCK="..."
# Часовой пояс для сопоставления даты/времени из Тильды со слотами в БД (date + time в query)
# EXHIBITION_TIMEZONE="Europe/Minsk"
# Опционально: явный список хостов для dev HMR, через запятую (если не хотите парсить APP_BASE_URL)
# ALLOWED_DEV_ORIGINS=192.168.1.7

# Секрет для JWT сессии персонала (случайная строка 32+ символов)
SESSION_SECRET="замените_на_случайную_длинную_строку"

# Режим разработки: пропустить bePaid и сразу «оплатить» заказ
DEV_SKIP_PAYMENT="true"
# Через сколько минут неоплаченный PENDING снимает бронь (лениво при новом checkout / открытии списка слотов в админке). По умолчанию 30.
# PENDING_ORDER_TTL_MINUTES="30"

# bePaid (когда подключите реальный магазин)
BEPAID_SHOP_ID=""
BEPAID_SECRET_KEY=""
# true = тестовая транзакция bePaid (test: true), см. https://docs.bepaid.by/ru/using_api/testing/
BEPAID_TEST="false"
# Checkout API (hosted page). Старый gateway …/beyag/payments даёт 404 — не используйте.
# По умолчанию в коде: https://checkout.bepaid.by/ctp/api/checkouts
# BEPAID_API_URL="https://checkout.bepaid.by/ctp/api/checkouts"
# Возвраты (Card API), по умолчанию: https://gateway.bepaid.by/transactions/refunds
# BEPAID_REFUND_URL="https://gateway.bepaid.by/transactions/refunds"

# Почта (после оплаты — билет на email). Без SMTP письма только логируются в консоль.
# Hoster mail.dei.by с Render: часто ETIMEDOUT на CONN — провайдер может не пускать SMTP с чужих IP.
# Тогда: поддержка хостинга, внешний SMTP, или деплой приложения на VPS у того же хостера.
# Gmail с хостинга: лучше 465 (SSL); 587 с датацентров иногда таймаутит.
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="tickets@dei.by"
# Опционально: таймауты мс (облако → SMTP иногда ETIMEDOUT).
# SMTP_CONNECTION_TIMEOUT_MS="120000"
# SMTP_GREETING_TIMEOUT_MS="30000"
# SMTP_IPV4_ONLY="false"
# Подробный лог SMTP в консоль (nodemailer debug). Только на время отладки.
# SMTP_DEBUG="true"

# CORS для POST /api/orders со страниц Тильды (origin через запятую). В dev не обязателен.
# Пример: PUBLIC_ORDERS_CORS_ORIGIN="https://project12345.tilda.ws,https://www.dei.by"
# PUBLIC_ORDERS_CORS_ORIGIN=""

# Вебхук в Tilda CRM / Make / свой приёмник (POST JSON). Пусто = не отправлять.
TILDA_CRM_WEBHOOK_URL=""
TILDA_CRM_WEBHOOK_SECRET=""

# Поддержка (текст на странице успеха)
SUPPORT_EMAIL="support@dei.by"

# Админка /admin и API /api/admin/*: случайная длинная строка (вводится на странице входа)
# ADMIN_API_SECRET=""
# Только если дергаете /api/admin/* с другого сайта — origin через запятую
# ADMIN_CORS_ORIGIN="https://другой-домен"
