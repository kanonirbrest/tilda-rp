# Скопируйте в .env и подставьте значения.
#
# Тот же токен, что ADMIN_API_SECRET на сервере (в JS-бандле на проде).
# VITE_ADMIN_TOKEN=
#
# Локально (npm run dev): можно VITE_API_BASE= пустым + VITE_DEV_PROXY_TARGET=http://127.0.0.1:3000
# Прод / GitHub Pages: полный URL Next.js без /
# VITE_API_BASE=https://dei-tickets.onrender.com
#
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:3001
