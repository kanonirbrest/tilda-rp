generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Slot {
  id         String   @id @default(cuid())
  title      String
  startsAt   DateTime
  /// Базовая цена в копейках (минорные единицы BYN; в админке ввод в рублях → ×100).
  priceCents Int
  /// В копейках. Опционально: разные цены для Тильды (взрослый / детский / льготный). Иначе везде priceCents.
  priceAdultCents      Int?
  priceChildCents      Int?
  priceConcessionCents Int?
  /// Максимум мест на сеанс (все типы билетов вместе). null = без лимита.
  capacity   Int?
  currency   String   @default("BYN")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  orders     Order[]
}

enum TicketTier {
  ADULT
  CHILD
  CONCESSION
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  createdAt DateTime @default(now())
  orders    Order[]
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  /// Деньги возвращены через bePaid (или помечено после ручного возврата в ЛК).
  REFUNDED
}

enum PromoDiscountKind {
  PERCENT
  FIXED_CENTS
}

model PromoCode {
  id             String            @id @default(cuid())
  /// Нормализованный код (верхний регистр), уникальный
  code           String            @unique
  active         Boolean           @default(true)
  discountKind   PromoDiscountKind
  /// PERCENT: 1–100. FIXED_CENTS: вычитаемые копейки (не больше суммы заказа).
  discountValue  Int
  /// Лимит одновременных заявок PENDING+PAID с этим промо; null = без лимита
  maxUses        Int?
  validFrom      DateTime?
  validUntil     DateTime?
  createdAt      DateTime          @default(now())
  orders         Order[]
}

model Order {
  id           String      @id @default(cuid())
  slotId       String
  slot         Slot        @relation(fields: [slotId], references: [id])
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  status       OrderStatus @default(PENDING)
  /// Сумма до скидки по промокоду (копейки).
  subtotalCents Int
  /// Скидка по промокоду, копейки (0 если промо нет).
  discountCents Int        @default(0)
  /// Сумма к оплате (как в bePaid `order.amount`).
  amountCents  Int
  currency     String      @default("BYN")
  /// Токен checkout из ответа создания оплаты; вебхук может сопоставлять и по нему.
  bepaidUid    String?     @unique
  /// UID транзакции списания в bePaid (`parent_uid` для возврата). Заполняется из вебхука.
  bepaidPaymentUid String? @unique
  createdAt    DateTime    @default(now())
  paidAt       DateTime?
  refundedAt   DateTime?
  promoCodeId  String?
  promoCode    PromoCode?  @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  tickets      Ticket[]
  lines        OrderLine[]

  @@index([promoCodeId])
}

model OrderLine {
  id             String     @id @default(cuid())
  orderId        String
  order          Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tier           TicketTier
  quantity       Int
  /// Цена строки в копейках за единицу.
  unitPriceCents Int
}

model Ticket {
  id          String    @id @default(cuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  publicToken String    @unique
  /// Тип билета (взрослый / детский / льготный). У старых записей может быть null.
  tier        TicketTier?
  /// Сколько человек по этому QR (вся группа за раз)
  admissionCount Int    @default(1)
  usedAt      DateTime?
  usedById    String?
  usedBy      StaffUser? @relation(fields: [usedById], references: [id])
  createdAt   DateTime  @default(now())

  @@index([orderId])
}

model StaffUser {
  id           String   @id @default(cuid())
  login        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  checkIns     Ticket[]
}

model WebhookReceipt {
  id         String   @id @default(cuid())
  provider   String
  externalId String   @unique
  createdAt  DateTime @default(now())
}
